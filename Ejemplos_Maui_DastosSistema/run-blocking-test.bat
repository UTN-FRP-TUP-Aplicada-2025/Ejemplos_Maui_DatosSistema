@echo off
REM Script para facilitar el testing de WebView Blocking en Windows

setlocal enabledelayedexpansion

if "%1"=="" (
    echo.
    echo ??????????????????????????????????????????
    echo ?  WebView Blocking Test - Launcher      ?
    echo ??????????????????????????????????????????
    echo.
    echo Uso: run-blocking-test.bat [accion] [opciones]
    echo.
    echo Acciones disponibles:
    echo   server              - Inicia solo el servidor WebAPI
    echo   app [platform]      - Inicia solo la app MAUI
    echo   logs                - Muestra logs de Android
    echo.
    echo Plataformas:
    echo   android (default)
    echo   ios
    echo   maccatalyst
    echo   windows
    echo.
    echo Ejemplos:
    echo   run-blocking-test.bat server
    echo   run-blocking-test.bat app android
    echo   run-blocking-test.bat logs
    echo.
    goto :EOF
)

set ACTION=%1
set PLATFORM=%2
if "!PLATFORM!"=="" set PLATFORM=android

if /i "!ACTION!"=="server" (
    call :StartServer
) else if /i "!ACTION!"=="app" (
    call :StartApp !PLATFORM!
) else if /i "!ACTION!"=="logs" (
    call :ShowLogs
) else (
    echo ? Accion no reconocida: !ACTION!
    goto :EOF
)

goto :EOF

:StartServer
echo.
echo ??????????????????????????????????????????
echo ?  ?? Iniciando WebAPI Server             ?
echo ??????????????????????????????????????????
echo.

if not exist "WebAPI_DatosSistema" (
    echo ? WebAPI_DatosSistema no encontrado
    exit /b 1
)

cd WebAPI_DatosSistema
echo ?? Directorio: %CD%
echo.
echo ? Servidor iniciando en http://localhost:5000
echo ?? Blocking Test: http://localhost:5000/blocking-test
echo.

dotnet run

goto :EOF

:StartApp
setlocal enabledelayedexpansion
echo.
echo ??????????????????????????????????????????
echo ?  ?? Iniciando MAUI App                  ?
echo ??????????????????????????????????????????
echo.

if not exist "Ejemplo_ReportSystemData" (
    echo ? Ejemplo_ReportSystemData no encontrado
    exit /b 1
)

cd Ejemplo_ReportSystemData
set PLATFORM=%~1
echo ?? Directorio: %CD%
echo ?? Plataforma: !PLATFORM!
echo.

set FRAMEWORK=net10.0-!PLATFORM!

dotnet run -f !FRAMEWORK!

goto :EOF

:ShowLogs
echo.
echo ??????????????????????????????????????????
echo ?  ?? Mostrando Logs                      ?
echo ??????????????????????????????????????????
echo.

echo ?? Conectando a dispositivo/emulador Android...
echo.
echo Presiona Ctrl+C para detener los logs
echo.

adb logcat --filters "MAUI:V *:S"

goto :EOF
